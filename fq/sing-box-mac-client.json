{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "store_fakeip": true,
      "store_rdrc": true
    },
    "clash_api": {
      "external_controller": "127.0.0.1:9191",
      "external_ui": "ui",
      "secret": "TODO_REPLACE_THIS",
      "default_mode": "rule"
    }
  },
  "dns": {
    "servers": [
      {
        "type": "hosts",
        "tag": "hosts"
      },
      {
        "type": "https",
        "tag": "google-dns",
        "server": "8.8.8.8",
        "detour": "proxy"
      },
      {
        "type": "local",
        "tag": "local-dns"
      },
      {
        "type": "https",
        "tag": "alidns",
        "server": "223.5.5.5"
      },
      {
        "type": "fakeip",
        "tag": "fakeip-dns",
        "inet4_range": "198.18.0.0/15",
        "inet6_range": "fc00::/18"
      }
    ],
    "rules": [
      {
        "ip_accept_any": true,
        "action": "route",
        "server": "hosts"
      },
      {
        "clash_mode": "Direct",
        "action": "route",
        "server": "local-dns"
      },
      {
        "clash_mode": "Global",
        "action": "route",
        "server": "google-dns"
      },
      {
        "rule_set": "geosite-ads",
        "action": "reject"
      },
      {
        "rule_set": [
          "geosite-cn",
          "geosite-apple-cn",
          "geosite-microsoft-cn",
          "geosite-google-cn",
          "geosite-steam-cn"
        ],
        "action": "route",
        "server": "alidns"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "action": "route",
        "server": "fakeip-dns"
      }
    ],
    "final": "google-dns",
    "strategy": "prefer_ipv4",
    "independent_cache": true
  },
  "inbounds": [
    {
      "type": "tun",
      "tag": "tun-in",
      "address": [
        "172.19.0.1/30",
        "fdfe:dcba:9876::1/126"
      ],
      "auto_route": true,
      "strict_route": true,
      "stack": "mixed"
    }
  ],
  "outbounds": [
    {
      "type": "selector",
      "tag": "proxy",
      "outbounds": [
        "auto",
        "us_west_o1",
        "direct"
      ],
      "default": "auto"
    },
    {
      "type": "selector",
      "tag": "google",
      "outbounds": [
        "proxy",
        "auto",
        "us_west_o1",
        "direct"
      ],
      "default": "proxy"
    },
    {
      "type": "selector",
      "tag": "microsoft",
      "outbounds": [
        "proxy",
        "auto",
        "us_west_o1",
        "direct"
      ],
      "default": "proxy"
    },
    {
      "type": "selector",
      "tag": "apple",
      "outbounds": [
        "direct",
        "proxy",
        "auto",
        "us_west_o1"
      ],
      "default": "direct"
    },
    {
      "type": "selector",
      "tag": "ai",
      "outbounds": [
        "proxy",
        "auto",
        "us_west_o1"
      ],
      "default": "proxy"
    },
    {
      "type": "selector",
      "tag": "steam",
      "outbounds": [
        "proxy",
        "auto",
        "us_west_o1",
        "direct"
      ],
      "default": "proxy"
    },
    {
      "type": "urltest",
      "tag": "auto",
      "outbounds": [
        "us_west_o1"
      ],
      "url": "https://www.gstatic.com/generate_204",
      "interval": "5m",
      "tolerance": 50
    },
    {
      "type": "direct",
      "tag": "direct"
    },
    {
      "type": "vless",
      "tag": "us_west_o1",
      "server": "TODO_REPLACE_THIS",
      "server_port": 443,
      "uuid": "TODO_REPLACE_THIS",
      "flow": "xtls-rprx-vision",
      "tls": {
        "enabled": true,
        "server_name": "TODO_REPLACE_THIS",
        "utls": {
          "enabled": true,
          "fingerprint": "chrome"
        },
        "reality": {
          "enabled": true,
          "public_key": "TODO_REPLACE_THIS",
          "short_id": "TODO_REPLACE_THIS"
        }
      }
    }
  ],
